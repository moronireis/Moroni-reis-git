  "components": {
    "button-primary": {
      "bg": "#ffffff",
      "text": "#000000",
      "border": "#000000",
      "radius": "0px",
      "padding": "10px 50px",
      "font": "14px Santral weight 600",
      "hover_bg": "#81d8d0"
    },
    "button-primary-hover": {
      "bg": "#81d8d0",
      "text": "#000000",
      "border": "#000000"
    },
    "button-secondary": {
      "bg": "#000000",
      "text": "#ffffff",
      "border": "#000000",
      "radius": "0px",
      "padding": "10px 40px",
      "font": "14px Santral weight 600",
      "hover_bg": "#81d8d0"
    },
    "button-secondary-hover": {
      "bg": "#81d8d0",
      "text": "#000000",
      "border": "#000000"
    },
    "button-ghost": {
      "bg": "transparent",
      "text": "#000000",
      "border": "transparent",
      "radius": "0px",
      "padding": "0px"
    },
    "card": {
      "text": "#000",
      "shadow": "none",
      "font_weight": "400",
      "cursor": "pointer",
      "transition": "transform .8s",
      "font_size": "18px",
      "variants": {
        "divider": {
          "padding": "1rem"
        },
        "section": {
          "padding": "1rem"
        }
      },
      "bg": "#ffffff",
      "border": "#e6e6e6",
      "radius": "0px",
      "padding": "16px"
    },
    "input-text": {
      "bg": "#ffffff",
      "text": "#000000",
      "border": "#e4e4e4",
      "radius": "0px",
      "padding": "4px 6px",
      "focus_border": "#81d8d0"
    },
    "badge-default": {
      "bg": "#81d8d0",
      "text": "#000000",
      "border": "#000000",
      "radius": "0px",
      "padding": "0px 6px",
      "font": "14px weight 600"
    },
    "nav-header": {
      "bg": "#81d8d0",
      "text": "#000000",
      "border_bottom": "#e4e4e4",
      "backdrop_filter": "none",
      "height": "63px"
    },
    "button": {
      "font_size": "14px",
      "padding": "10px 50px",
      "outline": "0",
      "cursor": "pointer",
      "text": "#000",
      "bg": "#cacaca",
      "font_weight": "600",
      "transition": "background .5s,color .5s",
      "opacity": "1",
      "transform": "translateY(-50%)",
      "shadow": "none",
      "states": {
        "focus": {
          "bg": "#126195",
          "text": "#000",
          "outline": "0",
          "shadow": "0 0 0 5px #19f"
        },
        "hover": {
          "bg": "#126195",
          "text": "#000",
          "cursor": "pointer"
        },
        "disabled": {
          "opacity": ".5",
          "cursor": "not-allowed"
        },
        "active": {
          "opacity": ".6"
        }
      },
      "variants": {
        "group-button": {
          "font_size": "1rem"
        },
        "small": {
          "font_size": ".75rem"
        },
        "large": {
          "font_size": "1.25rem"
        },
        "primary": {
          "bg": "#126195",
          "text": "#0c3d5d"
        },
        "secondary": {
          "bg": "#5e5e5e",
          "text": "#3b3b3b"
        },
        "success": {
          "bg": "#22bb5b",
          "text": "#157539"
        },
        "warning": {
          "bg": "#cc8b00",
          "text": "#805700"
        },
        "medium": {
          "font_size": "2em"
        },
        "cta": {
          "font_weight": "600",
          "font_size": "14px",
          "text": "#000"
        },
        "info": {
          "font_weight": "600",
          "font_size": "14px",
          "text": "#000",
          "padding": "10px 11px",
          "transition": "background .5s,color .5s"
        }
      }
    },
    "input": {
      "cursor": "pointer",
      "padding": "4px 6px",
      "text": "#000",
      "font_size": "px",
      "bg": "#f6e7eb",
      "shadow": "none",
      "transition": "box-shadow .5s,border-color .25s ease-in-out",
      "outline": "none",
      "states": {
        "disabled": {
          "cursor": "not-allowed",
          "bg": "#e6e6e6",
          "opacity": ".5"
        },
        "focus": {
          "bg": "#fff",
          "outline": "none",
          "shadow": "none",
          "transition": "box-shadow .5s,border-color .25s ease-in-out"
        }
      },
      "variants": {
        "group-label": {
          "padding": "0 1rem",
          "text": "#000"
        }
      }
    },
    "badge": {
      "radius": "50%",
      "padding": ".3em",
      "font_size": ".6rem",
      "text": "#000",
      "transform": "translateZ(0)",
      "font_weight": "400",
      "cursor": "pointer",
      "variants": {
        "primary": {
          "text": "#fff"
        },
        "secondary": {
          "text": "#000"
        },
        "success": {
          "text": "#000"
        },
        "warning": {
          "text": "#000"
        }
      }
    },
    "link": {
      "font_weight": "600",
      "cursor": "pointer",
      "text": "#000",
      "font_size": "14px",
      "bg": "transparent",
      "outline": "0",
      "transition": "background .5s,color .5s",
      "shadow": "none",
      "transform": "rotate(-90deg)",
      "states": {
        "focus": {
          "text": "#1468a0",
          "shadow": "0 0 6px 1px rgba(23,121,186,.5)",
          "outline": "none"
        },
        "hover": {
          "text": "#81d8d0",
          "shadow": "0 0 6px 1px rgba(23,121,186,.5)",
          "opacity": "1",
          "font_weight": "600"
        },
        "disabled": {
          "opacity": ".5",
          "cursor": "not-allowed"
        }
      },
      "variants": {
        "primary": {
          "text": "#fff"
        },
        "cta": {
          "font_weight": "600",
          "font_size": "14px",
          "text": "#000"
        },
        "info": {
          "text": "#000"
        },
        "link": {
          "font_weight": "400",
          "font_size": "24px",
          "text": "#000"
        }
      }
    },
    "nav": {
      "transition": "all .3s ease",
      "transform": "translateY(-100%)",
      "shadow": "none",
      "font_weight": "400",
      "font_size": "11px",
      "text": "#000",
      "cursor": "pointer",
      "radius": "50%",
      "opacity": "1"
    },
    "tab": {
      "text": "#000",
      "transition": "all .5s ease",
      "font_weight": "400",
      "font_size": "15px"
    },
    "alert": {
      "text": "#000",
      "font_size": "14px",
      "bg": "#f2dede",
      "cursor": "pointer",
      "variants": {
        "primary": {
          "bg": "#d7ecfa",
          "text": "#000"
        },
        "secondary": {
          "bg": "#eaeaea",
          "text": "#000"
        },
        "success": {
          "bg": "#e1faea",
          "text": "#000"
        },
        "warning": {
          "bg": "#fff3d9",
          "text": "#000"
        },
        "small": {
          "padding": ".5rem"
        },
        "large": {
          "padding": "3rem"
        }
      }
    },
    "table": {
      "text": "#000",
      "font_weight": "700",
      "font_size": "12px",
      "bg": "#fff",
      "states": {
        "hover": {
          "bg": "#f4f4f4"
        }
      }
    },
    "tooltip": {
      "font_weight": "700",
      "font_size": "1em",
      "text": "#dc3232",
      "padding": ".2em .8em",
      "cursor": "help",
      "bg": "#000"
    },
    "modal": {
      "transition": "opacity .5s ease,visibility .5s ease",
      "cursor": "pointer",
      "bg": "rgba(0,0,0,.45)",
      "transform": "translate(-50%,-50%)",
      "font_weight": "300",
      "font_size": "15px"
    },
    "label": {
      "font_weight": "300",
      "font_size": "10px",
      "cursor": "pointer",
      "text": "#767676",
      "padding": ".5625rem 0",
      "transition": "top .15s linear,font-size .15s linear,left .15s linear",
      "opacity": "1",
      "shadow": "none",
      "states": {
        "focus": {
          "outline": "none",
          "shadow": "none"
        }
      },
      "variants": {
        "primary": {
          "text": "#fff"
        },
        "secondary": {
          "text": "#000"
        },
        "success": {
          "text": "#000"
        },
        "warning": {
          "text": "#000"
        }
      }
    },
    "help_text": {
      "font_size": ".8125rem",
      "text": "#000"
    },
    "error_text": {
      "text": "#cc4b37",
      "font_weight": "700",
      "font_size": ".75rem"
    }
  }
}