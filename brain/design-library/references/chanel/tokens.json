  "components": {
    "button-primary": {
      "bg": "#000000",
      "text": "#f9f9f9",
      "border": "#000000",
      "radius": "0px",
      "padding": "16px 18px",
      "font": "14px abchanel-corpo weight 600",
      "hover_bg": "#1d1d1d"
    },
    "button-primary-hover": {
      "bg": "#1d1d1d",
      "text": "#f9f9f9"
    },
    "button-secondary": {
      "bg": "#f9f9f9",
      "text": "#1d1d1d",
      "border": "#1d1d1d",
      "radius": "0px",
      "padding": "16px 18px",
      "font": "14px abchanel-corpo weight 600",
      "hover_bg": "#f1f1f1"
    },
    "button-ghost": {
      "bg": "transparent",
      "text": "#1d1d1d",
      "border": "transparent",
      "radius": "0px",
      "padding": "0px"
    },
    "card": {
      "font_weight": "600",
      "font_size": ".875rem",
      "bg": "#f9f9f9",
      "cursor": "pointer",
      "transition": "border-color .2s ease-in-out",
      "outline": "auto",
      "outline_offset": ".125rem",
      "opacity": ".5",
      "text": "var(--color-primary-variant,#1d1d1d)",
      "radius": "0px",
      "transform": "translateX(-50%)",
      "states": {
        "hover": {
          "cursor": "pointer"
        }
      },
      "border": "transparent",
      "shadow": "none",
      "padding": "27px"
    },
    "input-text": {
      "bg": "transparent",
      "text": "#1d1d1d",
      "border": "#d8d8d8",
      "radius": "0px",
      "padding": "0px 0px 3px",
      "focus_border": "#1d1d1d"
    },
    "badge-default": {
      "bg": "#f9f9f9",
      "text": "#1d1d1d",
      "border": "#ececec",
      "radius": "0px",
      "padding": "5px 9px",
      "font": "11px abchanel-corpo weight 600"
    },
    "nav-header": {
      "bg": "#ffffff",
      "text": "#000000",
      "border_bottom": "#ececec",
      "backdrop_filter": "none",
      "height": "auto"
    },
    "button": {
      "cursor": "pointer",
      "text": "var(--color-primary-variant,#1d1d1d)",
      "transition": "-webkit-text-decoration-color .2s ease",
      "outline_offset": ".3125rem",
      "shadow": "none",
      "opacity": "1",
      "font_weight": "600",
      "font_size": ".875rem",
      "states": {
        "hover": {
          "cursor": "pointer",
          "bg": "#f1f1f1",
          "text": "var(--color-inverted-primary-variant,#1d1d1d)",
          "opacity": "1"
        },
        "disabled": {
          "bg": "#f9f9f9",
          "text": "#949494",
          "cursor": "not-allowed",
          "shadow": "none"
        },
        "focus-visible": {
          "outline": "none",
          "bg": "#0000",
          "opacity": "1",
          "outline_color": "#000",
          "outline_offset": ".5625rem",
          "shadow": "0 0 0 2px #fff,0 0 0 4px #000"
        },
        "active": {
          "bg": "#0000",
          "outline": "none"
        },
        "focus": {
          "bg": "#0000",
          "outline": "1px solid #1d1d1d",
          "opacity": "1"
        }
      }
    },
    "input": {
      "cursor": "default",
      "font_weight": "600",
      "font_size": ".75rem",
      "transition": "background-color 0s 600000s",
      "bg": "#0000",
      "text": "var(--color-secondary-light,#767676)",
      "outline": "none",
      "transform": "translateY(0)",
      "states": {
        "focus-visible": {
          "outline": ".125rem solid var(--color-primary-variant,#1d1d1d)"
        },
        "focus": {
          "outline": "none",
          "text": "#0000",
          "font_weight": "300",
          "font_size": ".8125rem"
        },
        "disabled": {
          "text": "var(--color-primary-disable,#949494)",
          "cursor": "not-allowed"
        }
      },
      "variants": {
        "link": {
          "text": "#cd0000"
        }
      }
    },
    "badge": {
      "font_weight": "600",
      "font_size": ".75rem",
      "text": "#000",
      "padding": ".0625rem .5625rem",
      "bg": "var(--color-tertiary-light,#ececec)"
    },
    "link": {
      "font_weight": "600",
      "font_size": ".875rem",
      "cursor": "pointer",
      "transition": "-webkit-text-decoration-color .2s ease",
      "text": "var(--color-primary-variant,#1d1d1d)",
      "bg": "var(--color-primary-variant,#1d1d1d)",
      "states": {
        "hover": {
          "transition": "all .2s ease",
          "opacity": ".7"
        },
        "focus-visible": {
          "text": "#fff",
          "opacity": "1",
          "outline": "none"
        }
      },
      "variants": {
        "link": {
          "font_weight": "400",
          "cursor": "pointer"
        }
      }
    },
    "nav": {
      "font_weight": "700",
      "font_size": ".875rem",
      "text": "var(--color-primary-variant,#1d1d1d)",
      "transition": "fill .2s",
      "transform": "scaleX(-1) translateX(-20.83%)",
      "cursor": "pointer",
      "bg": "var(--color-background,#fff)",
      "outline_offset": "-.25rem"
    },
    "tab": {
      "font_weight": "600",
      "font_size": ".6875rem",
      "text": "var(--color-secondary-light,#767676)",
      "transition": "color .2s",
      "bg": "#0000",
      "states": {
        "active": {
          "bg": "#0000"
        },
        "focus": {
          "bg": "#0000"
        },
        "focus-visible": {
          "bg": "#0000"
        }
      }
    },
    "alert": {
      "font_weight": "400",
      "font_size": ".875rem",
      "text": "var(--color-secondary-light,#767676)",
      "transform": "var(--bottom-nav-hidden, translateY(calc(((1 - var(--bottom-nav-visible, 1)) * 56px))))",
      "transition": "transform .3s ease-in-out",
      "bg": "var(--color-background,#fff)",
      "cursor": "pointer",
      "shadow": "inset 0 0 0 1px #fff",
      "states": {
        "focus-visible": {
          "radius": ".125rem",
          "outline": ".125rem solid var(--color-primary-variant,#1d1d1d)",
          "outline_offset": "-.125rem"
        }
      }
    },
    "tooltip": {
      "font_weight": "400",
      "font_size": ".875rem",
      "bg": "var(--color-background,#fff)",
      "text": "var(--color-secondary,#333)",
      "transform": "translateX(calc(var(--tooltip-edge, 0px) - var(--tooltip-arrow-margin, 0.3125rem)))",
      "padding": "var(--tooltip-padding, 1.125rem)"
    },
    "modal": {
      "font_weight": "600",
      "font_size": "1rem",
      "bg": "#0000",
      "text": "#fff",
      "radius": "50%",
      "transition": "opacity .4s ease-out",
      "transform": "translate(-50%)",
      "shadow": "0 0 18px #0000001a",
      "cursor": "pointer",
      "states": {
        "focus-visible": {
          "text": "#fff",
          "transform": "translate(-50%)",
          "opacity": "1",
          "outline": "none"
        }
      }
    },
    "label": {
      "font_weight": "300",
      "font_size": ".6875rem",
      "text": "var(--color-secondary-light,#767676)"
    },
    "help_text": {
      "text": "#333"
    },
    "error_text": {
      "font_weight": "300",
      "text": "#cd0000"
    }
  }
}