    },
    "nav-header": {
      "bg": "#fcf7f1",
      "text": "#000000",
      "border_bottom": "transparent",
      "backdrop_filter": "none",
      "height": "64px"
    },
    "button": {
      "font_size": "var(--font-size-body-m, .75rem)",
      "outline": "1px dotted ButtonText",
      "bg": "transparent",
      "text": "#000",
      "cursor": "pointer",
      "outline_offset": "-1px",
      "states": {
        "focus-visible": {
          "outline": "2px solid #000",
          "outline_offset": "2px",
          "outline_color": "#fff"
        },
        "focus": {
          "outline": "2px solid #fff",
          "outline_offset": "2px"
        }
      },
      "variants": {
        "service": {
          "bg": "transparent",
          "text": "#000",
          "cursor": "pointer"
        },
        "tertiary": {
          "outline_color": "#fff"
        }
      }
    },
    "input": {
      "font_size": "100%",
      "bg": "transparent",
      "text": "#000",
      "cursor": "pointer",
      "transition": "text-indent .3s ease-out",
      "variants": {
        "service": {
          "bg": "transparent",
          "text": "#fff0",
          "cursor": "pointer"
        }
      }
    },
    "link": {
      "bg": "transparent",
      "text": "#000",
      "font_size": "var(--font-size-body-m, .75rem)",
      "padding": "0 12px",
      "cursor": "pointer",
      "outline": "2px solid #fff",
      "outline_offset": "-1px",
      "states": {
        "hover": {
          "text": "#000"
        },
        "focus": {
          "outline": "2px solid #fff",
          "outline_offset": "var(--focus-offset, 2px)"
        },
        "focus-visible": {
          "outline_offset": "0",
          "outline": "2px solid #fff"
        }
      },
      "variants": {
        "service": {
          "text": "#000",
          "font_size": "var(--font-size-body-m, .75rem)"
        }
      }
    },
    "nav": {
      "font_weight": "var(--font-weight-700, 700)",
      "font_size": "var(--font-size-body-s, .6875rem)",
      "outline": "2px solid #000",
      "outline_offset": "0",
      "variants": {
        "menu-nav": {
          "font_weight": "var(--font-weight-700, 700)",
          "font_size": "var(--font-size-body-s, .6875rem)"
        },
        "service": {
          "font_weight": "var(--font-weight-700, 700)",
          "font_size": "var(--font-size-body-s, .6875rem)",
          "outline": "2px solid #000",
          "outline_offset": "0"
        }
      }
    },
    "alert": {
      "bg": "#ffffffe6",
      "transition": "visibility .2s ease-in .2s",
      "text": "#000",
      "padding": "16px 15px 8px",
      "font_size": "var(--font-size-body-l, 1rem)",
      "shadow": "inset 0 0 6px 6px #000",
      "states": {
        "hover": {
          "transform": "translateZ(0)",
          "shadow": "inset 0 0 6px 6px #000"
        }
      }
    },
    "tooltip": {
      "font_size": "var(--font-size-body-m, .75rem)",
      "text": "#000"
    },
    "modal": {
      "transition": "opacity .4s cubic-bezier(.25,.8,.25,1)",
      "bg": "#f5f5f5",
      "font_weight": "var(--font-weight-300, 300)",
      "text": "#000",
      "font_size": "var(--font-size-body-xl, 1rem)",
      "radius": "50%",
      "variants": {
        "service": {
          "bg": "#f5f5f5",
          "font_weight": "var(--font-weight-300, 300)",
          "text": "#000",
          "font_size": "var(--font-size-body-xl, 1rem)",
          "radius": "50%",
          "transition": "opacity,transform 0ms cubic-bezier(0,0,.2,1)"
        },
        "medium": {
          "font_weight": "var(--font-weight-500, 500)",
          "font_size": "var(--font-size-body-m, .75rem)"
        },
        "small": {
          "font_weight": "var(--font-weight-500, 500)",
          "font_size": "var(--font-size-body-s, .6875rem)"
        }
      }
    },
    "label": {
      "text": "#696969",
      "variants": {
        "medium": {
          "font_weight": "var(--font-weight-500, 500)",
          "font_size": "var(--font-size-body-m, .75rem)"
        },
        "small": {
          "font_weight": "var(--font-weight-500, 500)",
          "font_size": "var(--font-size-body-s, .6875rem)"
        }
      }
    }
