  "components": {
    "button-primary": {
      "bg": "#000000",
      "text": "#ffffff",
      "border": "#000000",
      "radius": "0px",
      "padding": "15px 0",
      "font": "14px bottegaveneta-bold-webfont weight 700",
      "hover_bg": "#000000"
    },
    "button-secondary": {
      "bg": "transparent",
      "text": "#000000",
      "border": "#000000",
      "radius": "0px",
      "padding": "15px 0",
      "font": "14px bottegaveneta-bold-webfont weight 700",
      "hover_bg": "transparent"
    },
    "button-disabled": {
      "bg": "transparent",
      "text": "#bfbfbf",
      "border": "#bfbfbf",
      "radius": "0px",
      "padding": "15px 0",
      "font": "14px bottegaveneta-bold-webfont weight 700"
    },
    "card": {
      "font_weight": "400",
      "font_size": ".875rem",
      "text": "#767676",
      "bg": "#ffffff",
      "states": {
        "active": {
          "text": "#000"
        },
        "hover": {
          "text": "#000"
        }
      },
      "border": "transparent",
      "radius": "0px",
      "shadow": "none",
      "padding": "0px"
    },
    "input-text": {
      "bg": "#ffffff",
      "text": "#000000",
      "border": "#000000",
      "radius": "0px",
      "padding": "9px 0",
      "focus_border": "#000000"
    },
    "badge-default": {
      "bg": "transparent",
      "text": "#000000",
      "border": "transparent",
      "radius": "0px",
      "padding": "0px",
      "font": "10px bottegaveneta-regular-webfont weight 400"
    },
    "nav-header": {
      "bg": "#ffffff",
      "text": "#000000",
      "border_bottom": "#d8d8d8",
      "backdrop_filter": "none",
      "height": "auto"
    },
    "tab-default": {
      "bg": "transparent",
      "text": "#000000",
      "border": "transparent",
      "radius": "0px",
      "padding": "0 0 15px",
      "font": "14px bottegaveneta-regular-webfont weight 400"
    },
    "button": {
      "font_size": ".875rem",
      "font_weight": "700",
      "outline": "1px solid #000",
      "text": "#000",
      "bg": "transparent",
      "outline_offset": "-.0625rem",
      "cursor": "pointer",
      "transform": "translateY(-50%)",
      "opacity": ".4",
      "transition": "-webkit-transform .2s linear",
      "shadow": "none",
      "states": {
        "focus": {
          "outline": "none",
          "text": "#000"
        },
        "hover": {
          "bg": "transparent",
          "cursor": "pointer",
          "text": "#000",
          "font_weight": "700"
        },
        "active": {
          "text": "#000"
        }
      }
    },
    "input": {
      "font_size": ".875rem",
      "outline": "0",
      "text": "#000",
      "cursor": "pointer",
      "transition": "all .2s linear",
      "transform": "scaleY(1.6)",
      "bg": "#fff",
      "font_weight": "400",
      "shadow": "none",
      "states": {
        "focus-visible": {
          "outline": "none"
        },
        "hover": {
          "cursor": "pointer",
          "transform": "scaleY(1.6)"
        },
        "focus": {
          "outline": "none"
        },
        "checked": {
          "bg": "#009539"
        }
      }
    },
    "badge": {
      "font_size": ".625rem",
      "text": "rgba(0,0,0,.4)"
    },
    "link": {
      "text": "#000",
      "bg": "transparent",
      "outline": "1px solid #000",
      "font_size": ".875rem",
      "cursor": "pointer",
      "outline_offset": "2px",
      "font_weight": "400",
      "transition": "all .2s linear",
      "transform": "scaleY(1.6)",
      "shadow": "none",
      "radius": ".1875rem",
      "states": {
        "focus": {
          "bg": "#eee",
          "outline": "none",
          "text": "#000",
          "outline_offset": "0",
          "cursor": "pointer",
          "transform": "none",
          "font_size": ".75rem"
        },
        "hover": {
          "bg": "#eee",
          "text": "#000",
          "cursor": "pointer",
          "transform": "scaleY(1.6)",
          "font_size": ".75rem"
        },
        "active": {
          "text": "#000",
          "bg": "#fff"
        }
      },
      "variants": {
        "link": {
          "outline": "none",
          "outline_offset": ".125rem"
        }
      }
    },
    "nav": {
      "bg": "#fff",
      "transition": "opacity 1s",
      "cursor": "pointer",
      "font_size": ".75rem",
      "outline": "1px solid #fff",
      "outline_offset": ".1875rem",
      "font_weight": "700",
      "transform": "translateX(100%)",
      "text": "#fff"
    },
    "tab": {
      "text": "#000",
      "padding": "0 0 .9375rem",
      "font_size": ".875rem",
      "font_weight": "400",
      "cursor": "help",
      "states": {
        "hover": {
          "bg": "#f1f3f2"
        }
      }
    },
    "alert": {
      "bg": "#fff",
      "font_size": ".875rem",
      "font_weight": "400",
      "transform": "translateX(0) matrix(1,0,0,1,0,0)",
      "text": "#767676",
      "opacity": "1",
      "transition": "opacity .2s ease-in,-webkit-transform .2s ease-in",
      "cursor": "pointer",
      "radius": "50%"
    },
    "table": {
      "font_weight": "400",
      "font_size": ".875rem",
      "padding": ".625rem",
      "text": "#000"
    },
    "tooltip": {
      "font_size": ".875rem",
      "text": "#000",
      "bg": "#fff"
    },
    "modal": {
      "padding": "0 1rem 1rem",
      "bg": "#fff",
      "opacity": "1",
      "transition": "opacity .1s ease-in,visibility 0ms ease-in .1s",
      "cursor": "pointer",
      "transform": "translateX(100%)"
    },
    "label": {
      "font_size": ".75rem",
      "text": "#272727"
    },
    "error_text": {
      "font_size": ".75rem",
      "text": "#eb0000"
    }
  }
}