---
import AppLayout from '../../layouts/AppLayout.astro';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

const supabase = createServerClient();

// Fetch ALL notifications for admin (not just admin's own — all users)
const { data: notifications } = await supabase
  .from('notifications')
  .select('*, user:profiles!notifications_user_id_fkey(id, full_name, email, role)')
  .order('created_at', { ascending: false })
  .limit(200);

const allNotifs = notifications || [];

const typeLabels: Record<string, string> = {
  system: 'Sistema',
  mentoria: 'Mentoria',
  task: 'Task',
  project_update: 'Projeto',
  comment: 'Comentário',
  reply: 'Resposta',
  message: 'Mensagem',
};

const typeColors: Record<string, string> = {
  system: '#4A90FF',
  mentoria: '#8B5CF6',
  task: '#F59E0B',
  project_update: '#22C55E',
  comment: '#4A90FF',
  reply: '#4A90FF',
  message: '#22C55E',
};

function timeAgo(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'agora';
  if (mins < 60) return `${mins}min`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h`;
  const days = Math.floor(hours / 24);
  return `${days}d`;
}
---

<AppLayout title="Notificações" activeSection="admin-notifications">
  <div style="margin-bottom: 24px;">
    <h2 style="font-size: 18px; font-weight: 600; color: var(--text-primary); margin: 0 0 6px 0;">Central de Notificações</h2>
    <p style="font-size: 13px; color: var(--text-tertiary); margin: 0;">Todas as atualizações dos usuários, checkpoints, feedbacks e atividades.</p>
  </div>

  <div style="display: flex; flex-direction: column; gap: 4px;">
    {allNotifs.map(n => {
      const color = typeColors[n.type] || '#4A90FF';
      const label = typeLabels[n.type] || n.type;
      const hasBody = n.body && n.body.length > 50;

      return (
        <div style={`padding: 14px 16px; border-radius: 10px; background: var(--surface-1); border: 1px solid ${n.read ? 'var(--border-subtle)' : `${color}20`}; ${!n.read ? `border-left: 3px solid ${color};` : ''}`}>
          <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 6px;">
            <div style="display: flex; align-items: center; gap: 8px; flex: 1; min-width: 0;">
              <span style={`font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 9999px; text-transform: uppercase; letter-spacing: 0.04em; background: ${color}15; color: ${color}; flex-shrink: 0;`}>
                {label}
              </span>
              <span style="font-size: 14px; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                {n.title}
              </span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px; flex-shrink: 0;">
              <span style="font-size: 11px; color: var(--text-quaternary);">{timeAgo(n.created_at)}</span>
              {n.link && (
                <a href={n.link} style={`font-size: 11px; color: ${color}; text-decoration: none;`}>Abrir</a>
              )}
            </div>
          </div>

          {/* Notification body — full content */}
          <div style="font-size: 13px; color: var(--text-secondary); line-height: 1.6; white-space: pre-wrap; word-break: break-word;">
            {n.body}
          </div>

          {/* Who this notification was sent to */}
          {n.user && (
            <div style="margin-top: 8px; font-size: 11px; color: var(--text-quaternary);">
              Para: {n.user.full_name || n.user.email}
              {n.user.role && ` (${n.user.role})`}
            </div>
          )}
        </div>
      );
    })}

    {allNotifs.length === 0 && (
      <div style="text-align: center; padding: 40px 0; color: var(--text-quaternary); font-size: 14px;">
        Nenhuma notificação ainda.
      </div>
    )}
  </div>
</AppLayout>
