---
import AppLayout from '../../layouts/AppLayout.astro';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

const supabase = createServerClient();

const { data: entries } = await supabase
  .from('hub_knowledge')
  .select('*, user:profiles!hub_knowledge_user_id_fkey(id, full_name, email, role)')
  .order('created_at', { ascending: false })
  .limit(100);

const allEntries = entries || [];

const categoryLabels: Record<string, string> = {
  form_response: 'Formulário',
  checkpoint_feedback: 'Checkpoint',
  survey_response: 'Pesquisa',
  research: 'Pesquisa',
  meeting_notes: 'Reunião',
  client_data: 'Cliente',
  agent_output: 'Agente',
  general: 'Geral',
};

const categoryColors: Record<string, string> = {
  form_response: '#8B5CF6',
  checkpoint_feedback: '#F59E0B',
  survey_response: '#4A90FF',
  research: '#22C55E',
  meeting_notes: '#4A90FF',
  client_data: '#EC4899',
  agent_output: '#22C55E',
  general: 'rgba(255,255,255,0.4)',
};

function timeAgo(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'agora';
  if (mins < 60) return `${mins}min`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h`;
  const days = Math.floor(hours / 24);
  if (days < 30) return `${days}d`;
  return new Date(dateStr).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' });
}
---

<AppLayout title="Banco de Dados" activeSection="admin-knowledge">
  <div style="margin-bottom: 24px;">
    <h2 style="font-size: 18px; font-weight: 600; color: var(--text-primary); margin: 0 0 6px 0;">Banco de Dados REIS [IA]</h2>
    <p style="font-size: 13px; color: var(--text-tertiary); margin: 0;">
      Todas as respostas de formulários, feedbacks, pesquisas e dados coletados.
      <span style="color: var(--text-quaternary);">{allEntries.length} registros</span>
    </p>
  </div>

  <div style="display: flex; flex-direction: column; gap: 6px;">
    {allEntries.map(entry => {
      const color = categoryColors[entry.category] || '#4A90FF';
      const label = categoryLabels[entry.category] || entry.category;

      return (
        <details style={`border-radius: 10px; background: var(--surface-1); border: 1px solid var(--border-subtle); overflow: hidden;`}>
          <summary style="padding: 14px 16px; cursor: pointer; display: flex; align-items: center; gap: 12px; list-style: none;">
            <span style={`font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 9999px; text-transform: uppercase; letter-spacing: 0.04em; background: ${color}15; color: ${color}; flex-shrink: 0;`}>
              {label}
            </span>
            <span style="font-size: 14px; font-weight: 500; color: var(--text-primary); flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              {entry.title}
            </span>
            {entry.user && (
              <span style="font-size: 11px; color: var(--text-quaternary); flex-shrink: 0;">
                {entry.user.full_name}
              </span>
            )}
            <span style="font-size: 11px; color: var(--text-quaternary); flex-shrink: 0;">
              {timeAgo(entry.created_at)}
            </span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="flex-shrink: 0; color: var(--text-quaternary); transition: transform 200ms;">
              <path d="M4 5.5L7 8.5L10 5.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </summary>

          <div style="padding: 0 16px 16px; border-top: 1px solid var(--border-subtle);">
            {/* Summary */}
            {entry.summary && (
              <div style="padding: 10px 0 0; font-size: 13px; color: var(--accent-blue); font-style: italic;">
                {entry.summary}
              </div>
            )}

            {/* Full content */}
            <div style="padding: 12px 0; font-size: 13px; color: var(--text-secondary); line-height: 1.7; white-space: pre-wrap; word-break: break-word; max-height: 400px; overflow-y: auto;">
              {entry.content}
            </div>

            {/* Metadata */}
            <div style="display: flex; flex-wrap: wrap; gap: 12px; font-size: 11px; color: var(--text-quaternary); padding-top: 8px; border-top: 1px solid var(--border-subtle);">
              {entry.source && <span>Fonte: {entry.source}</span>}
              {entry.user?.email && <span>Email: {entry.user.email}</span>}
              {entry.tags && entry.tags.length > 0 && (
                <span>Tags: {entry.tags.join(', ')}</span>
              )}
              <span>{new Date(entry.created_at).toLocaleString('pt-BR')}</span>
            </div>
          </div>
        </details>
      );
    })}

    {allEntries.length === 0 && (
      <div style="text-align: center; padding: 60px 0;">
        <p style="color: var(--text-tertiary); font-size: 15px; font-weight: 500; margin-bottom: 6px;">Nenhum registro ainda</p>
        <p style="color: var(--text-quaternary); font-size: 13px;">Os dados aparecerão aqui conforme formulários forem preenchidos e feedbacks enviados.</p>
      </div>
    )}
  </div>
</AppLayout>

<style>
  details[open] summary svg {
    transform: rotate(180deg);
  }
  details summary::-webkit-details-marker {
    display: none;
  }
</style>
