---
import AuthLayout from '../layouts/AuthLayout.astro';
import CreateAccountForm from '../components/CreateAccountForm.tsx';

export const prerender = false;

const emailParam = Astro.url.searchParams.get('email') || '';
---

<AuthLayout title="Obrigado pela compra">
  <div class="text-center mb-8">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium mb-6" style="background: var(--color-success-bg); color: var(--color-success); border: 1px solid rgba(34, 197, 94, 0.2);">
      Compra confirmada
    </div>
    <h1 class="text-2xl font-medium mb-2" style="color: var(--text-primary);">
      Obrigado pela compra!
    </h1>
    <p class="text-sm" style="color: var(--text-tertiary); max-width: 360px; margin: 0 auto;">
      Crie sua conta abaixo para acessar o conteúdo. Use o mesmo email da compra.
    </p>
  </div>

  <CreateAccountForm
    client:load
    defaultEmail={emailParam}
  />
</AuthLayout>

<style>
  .input-field:focus {
    border-color: var(--border-accent) !important;
    box-shadow: 0 0 0 3px var(--blue-08);
  }
  .submit-btn:hover:not(:disabled) {
    background: var(--accent-blue-hover) !important;
  }
</style>
