---
const clientName = import.meta.env.CLIENT_NAME || 'Tarefas';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{clientName} — Tarefas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      font-family: 'Source Sans 3', -apple-system, BlinkMacSystemFont, sans-serif;
      background: #0A0A0A;
      color: #fff;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 28px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      background: #050505;
    }

    .header-left {
      display: flex;
      align-items: center;
    }

    .header-brand {
      font-family: 'Montserrat', sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: #DBA99F;
      letter-spacing: 1.5px;
    }

    .header-divider {
      width: 1px;
      height: 16px;
      background: rgba(255,255,255,0.12);
      margin: 0 14px;
    }

    .header-section {
      font-family: 'Montserrat', sans-serif;
      font-size: 11px;
      font-weight: 400;
      color: rgba(255,255,255,0.4);
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }

    .main-content {
      max-width: 1400px;
      margin: 0 auto;
      padding: 20px 24px;
    }

    @media (max-width: 640px) {
      .header {
        padding: 12px 16px;
      }
      .header-brand {
        font-size: 12px;
      }
      .main-content {
        padding: 16px;
      }
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="header-left">
      <span class="header-brand">NOIVA SA</span>
      <div class="header-divider"></div>
      <span class="header-section">Marketing</span>
    </div>
  </header>
  <main class="main-content">
    <slot />
  </main>
</body>
</html>
